# Local development only. Do not commit real secrets.
DASHSCOPE_API_KEY=replace-with-local-secret
MIXLAB_ALLOW_TEMP_RUNTIME_PATHS=0
MIXLAB_ASR_MODEL=paraformer-v2
MIXLAB_ENABLE_LIVE_ASR=0
MIXLAB_ASR_AUDIO_URL=
MIXLAB_ASR_SOURCE_VIDEO_ID=V_LIVE_CHECK
MIXLAB_ASR_MAX_POLL_ATTEMPTS=60
MIXLAB_ASR_POLL_INTERVAL_MS=3000
MIXLAB_ENABLE_LIVE_DASHSCOPE_TEMP_UPLOAD=0
MIXLAB_TEMP_UPLOAD_FILE=
MIXLAB_FFMPEG_PATH=
MIXLAB_FFPROBE_PATH=

# Optional legacy Aliyun OSS local/runtime config. Default preprocessing uses DashScope temporary upload instead.
ALIYUN_OSS_BUCKET=replace-with-bucket
ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_REGION=oss-cn-beijing
ALIYUN_OSS_ACCESS_KEY_ID=replace-with-local-secret
ALIYUN_OSS_ACCESS_KEY_SECRET=replace-with-local-secret
MIXLAB_OSS_URL_MODE=signed-url
MIXLAB_OSS_SIGNED_URL_EXPIRES_SECONDS=900
MIXLAB_OSS_PUBLIC_BASE_URL=
MIXLAB_OSS_OBJECT_PREFIX=mixlab
MIXLAB_ENABLE_LIVE_OSS_UPLOAD=0
MIXLAB_OSS_LIVE_UPLOAD_FILE=

# Controlled end-to-end live preprocessing. Default uploader is DashScope temporary storage.
MIXLAB_ENABLE_LIVE_PREPROCESS=0
MIXLAB_PREPROCESS_SOURCE_VIDEO_PATH=
MIXLAB_PREPROCESS_LIBRARY_ROOT=
MIXLAB_PREPROCESS_LIBRARY_ID=lib_main_001
MIXLAB_PREPROCESS_SOURCE_VIDEO_ID=V_LIVE_CHECK
MIXLAB_PREPROCESS_AUDIO_MODE=mp3_16k_mono_64k

# Controlled directory-level live preprocessing. Runs sequentially and continues after per-video failures.
MIXLAB_ENABLE_LIVE_PREPROCESS_BATCH=0
MIXLAB_PREPROCESS_SOURCE_DIR=
MIXLAB_PREPROCESS_BATCH_ID_PREFIX=V_LIVE_BATCH
MIXLAB_PREPROCESS_BATCH_LIMIT=2
MIXLAB_PREPROCESS_BATCH_FILE_NAMES=

# Controlled production-shaped public library preprocessing worker.
# Expects MIXLAB_PREPROCESS_LIBRARY_ROOT/source-videos to contain source videos.
MIXLAB_ENABLE_LIBRARY_PREPROCESS_WORKER=0
MIXLAB_PREPROCESS_LIBRARY_NAME=主素材库
MIXLAB_PREPROCESS_WORKER_ID=worker-local-1
MIXLAB_PREPROCESS_WORKER_LIMIT=2
MIXLAB_PREPROCESS_FILE_IDENTITY_MODE=stat

# Controlled ready-publication worker. Generates cover/keyframes, publishes index package, then marks videos ready.
MIXLAB_ENABLE_READY_PUBLISH_WORKER=0
MIXLAB_READY_COVER_AT_MS=1000
MIXLAB_READY_COVER_WIDTH=640
MIXLAB_READY_KEYFRAME_INTERVAL_MS=5000
MIXLAB_READY_KEYFRAME_MAX_COUNT=60

# Local admin-side management API. Falls back to MIXLAB_PREPROCESS_LIBRARY_ROOT when unset.
# Formal runs must use a persistent directory such as a mounted drive, NAS, or
# ~/Library/Application Support/MixLab V3/PublicLibrary. Do not use /tmp.
MIXLAB_ADMIN_LIBRARY_ROOT=
MIXLAB_ADMIN_LIBRARY_ID=lib_main_001
MIXLAB_ADMIN_LIBRARY_NAME=主素材库
MIXLAB_ADMIN_API_HOST=127.0.0.1
MIXLAB_ADMIN_API_PORT=3889
VITE_MIXLAB_ADMIN_API_BASE_URL=http://127.0.0.1:3889

# Local cutter-side HTTP bridge. Falls back to MIXLAB_PREPROCESS_LIBRARY_ROOT when library root is unset.
# Formal runs must point to the same persistent public library root as the admin API.
# MIXLAB_CUTTER_WORKSPACE_ROOT defaults to ~/Movies/MixLabLocal so local cut jobs stay enabled after restart.
MIXLAB_CUTTER_LIBRARY_ROOT=
MIXLAB_CUTTER_WORKSPACE_ROOT=
MIXLAB_CUTTER_API_HOST=127.0.0.1
MIXLAB_CUTTER_API_PORT=3789
VITE_MIXLAB_CUTTER_API_BASE_URL=http://127.0.0.1:3789

# Controlled live audio format benchmark. Includes WAV baseline for text similarity.
MIXLAB_ENABLE_LIVE_AUDIO_FORMAT_BENCHMARK=0
MIXLAB_AUDIO_BENCHMARK_SOURCE_VIDEO_PATH=
MIXLAB_AUDIO_BENCHMARK_LIBRARY_ROOT=
MIXLAB_AUDIO_BENCHMARK_SOURCE_VIDEO_ID=V_AUDIO_BENCH
MIXLAB_AUDIO_BENCHMARK_VARIANTS=
