    "audit:target-evidence-readiness": "tsx scripts/acceptance/target-evidence-readiness.ts",
    "template:windows-evidence": "tsx scripts/acceptance/target-evidence-template.ts windows",
    "template:nas-evidence": "tsx scripts/acceptance/target-evidence-template.ts nas",
    "collect:windows-evidence": "powershell -ExecutionPolicy Bypass -File scripts/acceptance/windows-acc-008-collector.ps1",
    "collect:nas-evidence": "sh scripts/acceptance/nas-acc-009-collector.sh",
    "package:evidence-kit": "tsx scripts/acceptance/package-evidence-kit.ts",
    "validate:evidence-kit-manifest": "tsx scripts/acceptance/evidence-kit-manifest.ts",
    "validate:evidence-kit-drafts": "tsx scripts/acceptance/evidence-kit-drafts.ts",
    "validate:nas-docker-compose-static": "tsx scripts/acceptance/nas-docker-compose-static.ts",
    "audit:local-web-sanity": "tsx scripts/acceptance/local-web-sanity.ts",
    "status:local-real-nas": "tsx scripts/acceptance/local-real-nas-status.ts",
    "validate:local-web-sanity-report": "tsx scripts/acceptance/local-web-sanity-report.ts",
    "sync:local-real-nas-record": "tsx scripts/acceptance/sync-local-web-real-nas-record.ts",
    "audit:local-real-nas-phase": "tsx scripts/acceptance/local-real-nas-phase.ts",
    "audit:delivery-readiness": "tsx scripts/acceptance/delivery-readiness.ts",
    "test:acceptance-evidence": "node --test --import tsx scripts/acceptance/*.test.ts",
    "dev:cutter-desktop": "npm run dev -w @mixlab/cutter-desktop",
    "build:cutter-desktop": "npm run package:cutter-desktop:windows",
    "package:cutter-desktop:windows": "tsx scripts/desktop/package-windows-desktop.ts",
    "prepare:cutter-desktop:windows-assets": "tsx scripts/desktop/prepare-windows-runtime-assets.ts",
    "verify:cutter-desktop:windows-assets": "tsx scripts/desktop/verify-windows-runtime-assets.ts",
    "dev:ui-fixtures": "npm run dev -w @mixlab/ui-fixtures",
    "build:ui-fixtures": "npm run build -w @mixlab/ui-fixtures",
    "visual:ui-foundation": "tsx scripts/visual/check-ui-foundation-screenshots.ts",
    "build:searchd": "cargo build --manifest-path packages/searchd/Cargo.toml --release",
    "test:searchd": "cargo test --manifest-path packages/searchd/Cargo.toml",
    "test": "node --test --import tsx packages/*/src/*.test.ts apps/*/src/*.test.ts scripts/acceptance/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0",
    "playwright": "^1.56.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
