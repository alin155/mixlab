    "spike:path-resolution": "tsx scripts/spikes/path-resolution.ts",
    "spike:search": "tsx scripts/spikes/search.ts",
    "spike:ffmpeg-plan": "tsx scripts/spikes/ffmpeg-plan.ts",
    "spike:ffmpeg-real-cut": "tsx scripts/spikes/ffmpeg-real-cut.ts",
    "spike:ffmpeg-extract-audio": "tsx scripts/spikes/ffmpeg-extract-audio.ts",
    "spike:oss-upload-plan": "tsx scripts/spikes/oss-upload-plan.ts",
    "spike:oss-client-factory": "tsx scripts/spikes/oss-client-factory.ts",
    "spike:oss-live-upload": "tsx scripts/spikes/oss-live-upload.ts",
    "spike:asr-request": "tsx scripts/spikes/asr-request.ts",
    "spike:dashscope-temp-upload": "tsx scripts/spikes/dashscope-temp-upload.ts",
    "spike:asr-live-run": "tsx scripts/spikes/asr-live-run.ts",
    "spike:asr-artifact-write": "tsx scripts/spikes/asr-artifact-write.ts",
    "spike:audio-format-benchmark": "tsx scripts/spikes/audio-format-benchmark.ts",
    "spike:preprocess-live-batch": "tsx scripts/spikes/preprocess-live-batch.ts",
    "spike:preprocess-live-text-pipeline": "tsx scripts/spikes/preprocess-live-text-pipeline.ts",
    "spike:preprocess-text-pipeline": "tsx scripts/spikes/preprocess-text-pipeline.ts",
    "worker:preprocess-library": "tsx scripts/workers/preprocess-library-worker.ts",
    "worker:publish-ready": "tsx scripts/workers/publish-ready-worker.ts",
    "worker:admin-loop": "tsx scripts/docker/admin-worker-loop.ts",
    "server:admin-api": "tsx scripts/servers/admin-api-server.ts",
    "server:searchd": "cargo run --manifest-path packages/searchd/Cargo.toml --",
    "server:cutter-api": "tsx scripts/servers/cutter-api-server.ts",
    "dev:admin-web": "npm run dev -w @mixlab/admin-web",
    "build:admin-web": "npm run build -w @mixlab/admin-web",
    "visual:admin-web": "tsx scripts/visual/check-admin-web-screenshots.ts",
    "dev:cutter-web": "npm run dev -w @mixlab/cutter-web",
    "build:cutter-web": "npm run build -w @mixlab/cutter-web",
    "visual:cutter-web": "tsx scripts/visual/check-cutter-web-screenshots.ts",
    "smoke:cutter-api-web": "tsx scripts/smoke/cutter-api-web.ts",
    "smoke:searchd-concurrency": "tsx scripts/smoke/searchd-concurrency.ts",
    "smoke:searchd-nas-rehearsal": "tsx scripts/smoke/searchd-nas-rehearsal.ts",
    "smoke:real-nas-50-editor": "tsx scripts/smoke/real-nas-50-editor.ts",
    "smoke:searchd-scale": "tsx scripts/smoke/searchd-scale.ts",
    "validate:windows-evidence": "tsx scripts/acceptance/target-evidence.ts windows",
    "validate:nas-evidence": "tsx scripts/acceptance/target-evidence.ts nas",
