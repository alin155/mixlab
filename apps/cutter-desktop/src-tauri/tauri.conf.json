{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MixLab Cutter",
  "version": "0.18.9",
  "identifier": "com.mixlab.cutter",
  "build": {
    "beforeDevCommand": "npm run dev:cutter-web",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../cutter-web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MixLab Cutter",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "publisher": "MixLab",
    "category": "Productivity",
    "externalBin": ["binaries/cutter-api-sidecar"],
    "resources": [
      "binaries/cutter-api-sidecar-x86_64-pc-windows-msvc.exe",
      "binaries/ffmpeg.exe",
      "binaries/ffprobe.exe",
      "resources/default-desktop-config.json"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installerHooks": "./windows/installer-hooks.nsh"
      }
    }
  }
}
